# ── ערכים ציבוריים (בטוח להיות בקוד הצד-לקוח) ──
# מגיעים מ-Supabase: Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ── secrets (רק בשרת / ב-Edge Function — לעולם לא בקוד הלקוח) ──
# מוגדרים דרך: supabase secrets set ...
GROQ_API_KEY=YOUR-GROQ-KEY
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY
